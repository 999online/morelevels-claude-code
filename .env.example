# OPTIONAL — for developers only. Non-devs don't need this: /morelevels saves the token to
# ~/.morelevels.json on first run. These env vars, if set, OVERRIDE that config file.
# Never commit real values.

# morelevels API base URL. Omit/leave blank to use the server's DEFAULT_API_URL.
MORELEVELS_API_URL=http://localhost:8787

# Bearer submission token. Mint from the morelevels dashboard, or locally:
#   curl -X POST $MORELEVELS_API_URL/dev/mint-token -H 'content-type: application/json' -d '{"email":"you@example.com"}'
MORELEVELS_TOKEN=
