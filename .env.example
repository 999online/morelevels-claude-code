# morelevels plugin — copy to your shell env (never commit real values).
# The bundled plugins/morelevels/.mcp.json passes these through to the MCP server.

# morelevels API base URL. Omit/leave blank to use the default http://localhost:8787
MORELEVELS_API_URL=http://localhost:8787

# Bearer submission token. Mint from the morelevels dashboard, or locally:
#   curl -X POST $MORELEVELS_API_URL/dev/mint-token -H 'content-type: application/json' -d '{"email":"you@example.com"}'
MORELEVELS_TOKEN=
